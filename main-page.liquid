{{ 'section-main-page.css' | asset_url | stylesheet_tag }}
{% render 'custom-styles' %}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .page-cta-block {
    margin-top: 4rem;
    padding: 3rem 2.5rem;
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
    border-radius: 8px;
    text-align: center;
    border: 1px solid rgba(255,255,255,0.1);
  }

  .page-cta-block .cta-heading {
    color: #ffffff !important;
    font-size: 2.4rem;
    margin: 0 0 1rem 0;
  }

  .page-cta-block .cta-text {
    color: rgba(255,255,255,0.85) !important;
    font-size: 1.6rem;
    margin: 0 0 2rem 0;
  }

  .page-cta-block .cta-buttons {
    display: flex;
    gap: 1.2rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .page-cta-block .button--cta-primary {
    background: #ffffff;
    color: #111111 !important;
    padding: 1.2rem 2.8rem;
    border-radius: 6px;
    font-weight: 700;
    font-size: 1.5rem;
    text-decoration: none;
    display: inline-block;
    transition: opacity 0.2s;
  }

  .page-cta-block .button--cta-primary:hover {
    opacity: 0.9;
    color: #111111 !important;
  }

  .page-cta-block .button--cta-secondary {
    background: transparent;
    color: #ffffff !important;
    padding: 1.2rem 2.8rem;
    border-radius: 6px;
    font-weight: 600;
    font-size: 1.5rem;
    text-decoration: none;
    display: inline-block;
    border: 2px solid rgba(255,255,255,0.6);
    transition: border-color 0.2s;
  }

  .page-cta-block .button--cta-secondary:hover {
    border-color: #ffffff;
    color: #ffffff !important;
  }
{%- endstyle -%}

<div class="page-width page-width--narrow section-{{ section.id }}-padding">
  <h1 class="main-page-title page-title h0{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
    {{ page.title | escape }}
  </h1>

  {% capture bass_analyzer_markup %}
  <div id="ezba-inline-anchor"></div>
  <style>
    #ezba-custom {
      --ezba-bg: #0f0f10;
      --ezba-surface: #171719;
      --ezba-surface-2: #1e1e21;
      --ezba-border: rgba(255,255,255,0.10);
      --ezba-border-strong: rgba(232,164,0,0.30);
      --ezba-text: #f5f5f5;
      --ezba-muted: rgba(255,255,255,0.72);
      --ezba-faint: rgba(255,255,255,0.52);
      --ezba-gold: #e8a400;
      --ezba-gold-soft: rgba(232,164,0,0.14);
      --ezba-shadow: 0 18px 40px rgba(0,0,0,0.28);
      color: var(--ezba-text);
      margin: 32px 0;
      font-family: inherit;
    }

    #ezba-custom * { box-sizing: border-box; }

    #ezba-custom .ezba-wrap {
      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0));
      border: 1px solid var(--ezba-border);
      border-radius: 20px;
      padding: 24px;
      box-shadow: var(--ezba-shadow);
      background-color: var(--ezba-bg);
    }

    #ezba-custom .ezba-head { margin-bottom: 24px; }

    #ezba-custom .ezba-kicker {
      margin: 0 0 8px;
      color: var(--ezba-gold);
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-size: 12px;
      font-weight: 700;
    }

    #ezba-custom .ezba-title {
      margin: 0 0 10px;
      color: #fff;
      font-size: clamp(28px, 4vw, 40px);
      line-height: 1.08;
    }

    #ezba-custom .ezba-intro {
      margin: 0;
      max-width: 760px;
      color: var(--ezba-muted);
      font-size: 16px;
      line-height: 1.65;
    }

    #ezba-custom .ezba-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.65fr) minmax(280px, 0.9fr);
      gap: 20px;
      align-items: start;
    }

    #ezba-custom .ezba-panel {
      background: var(--ezba-surface);
      border: 1px solid var(--ezba-border);
      border-radius: 18px;
      padding: 20px;
    }

    #ezba-custom .ezba-controls,
    #ezba-custom .ezba-copy,
    #ezba-custom .ezba-peak-list-wrap {
      display: grid;
      gap: 10px;
    }

    #ezba-custom .ezba-label {
      color: #fff;
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    #ezba-custom .ezba-file {
      width: 100%;
      border-radius: 12px;
      border: 1px solid var(--ezba-border);
      background: var(--ezba-surface-2);
      color: var(--ezba-text);
      padding: 14px 16px;
    }

    #ezba-custom .ezba-file::file-selector-button {
      margin-right: 14px;
      border: 0;
      border-radius: 10px;
      background: var(--ezba-gold);
      color: #111;
      padding: 10px 14px;
      font-weight: 700;
      cursor: pointer;
    }

    #ezba-custom .ezba-help,
    #ezba-custom .ezba-disclaimer,
    #ezba-custom .ezba-steps,
    #ezba-custom .ezba-guide-list {
      margin: 0;
      color: var(--ezba-faint);
      font-size: 14px;
      line-height: 1.65;
    }

    #ezba-custom .ezba-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 2px;
    }

    #ezba-custom .ezba-btn {
      appearance: none;
      border: 1px solid transparent;
      border-radius: 12px;
      padding: 12px 16px;
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
      transition: transform 140ms ease, border-color 140ms ease, background 140ms ease, color 140ms ease;
    }

    #ezba-custom .ezba-btn:hover { transform: translateY(-1px); }
    #ezba-custom .ezba-btn-primary { background: var(--ezba-gold); color: #111; }
    #ezba-custom .ezba-btn-secondary { background: transparent; color: #fff; border-color: var(--ezba-border); }

    #ezba-custom .ezba-status {
      margin-top: 16px;
      padding: 12px 14px;
      border-radius: 12px;
      background: var(--ezba-surface-2);
      border: 1px solid var(--ezba-border);
      color: var(--ezba-muted);
      font-size: 14px;
    }

    #ezba-custom .ezba-results {
      margin-top: 18px;
      display: grid;
      gap: 18px;
    }

    #ezba-custom .ezba-cards {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 12px;
    }

    #ezba-custom .ezba-card {
      border: 1px solid var(--ezba-border);
      background: linear-gradient(180deg, rgba(232,164,0,0.06), rgba(255,255,255,0.01));
      border-radius: 16px;
      padding: 16px;
      display: grid;
      gap: 8px;
    }

    #ezba-custom .ezba-card-label {
      color: var(--ezba-faint);
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    #ezba-custom .ezba-card-value {
      color: #fff;
      font-size: clamp(20px, 2.5vw, 28px);
      line-height: 1.1;
    }

    #ezba-custom .ezba-peak-list {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    #ezba-custom .ezba-chip {
      border-radius: 999px;
      padding: 8px 12px;
      background: var(--ezba-gold-soft);
      border: 1px solid var(--ezba-border-strong);
      color: #fff;
      font-size: 13px;
      font-weight: 700;
    }

    #ezba-custom .ezba-chart-wrap {
      border-radius: 18px;
      overflow: hidden;
      border: 1px solid var(--ezba-border);
      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0)), var(--ezba-surface-2);
      padding: 14px;
    }

    #ezba-custom .ezba-chart-wrap canvas {
      width: 100%;
      display: block;
    }

    #ezba-custom .ezba-recommendation {
      margin: 0;
      color: #fff;
      font-size: 15px;
      line-height: 1.75;
    }

    #ezba-custom .ezba-side-title,
    #ezba-custom .ezba-guide-title {
      margin: 0 0 12px;
      color: #fff;
      font-size: 18px;
    }

    #ezba-custom .ezba-steps,
    #ezba-custom .ezba-guide-list {
      padding-left: 18px;
    }

    #ezba-custom .ezba-guide-box {
      margin-top: 18px;
      border-radius: 16px;
      padding: 16px;
      background: var(--ezba-surface-2);
      border: 1px solid var(--ezba-border);
    }

    @media screen and (max-width: 989px) {
      #ezba-custom .ezba-grid { grid-template-columns: 1fr; }
    }

    @media screen and (max-width: 749px) {
      #ezba-custom .ezba-wrap,
      #ezba-custom .ezba-panel {
        padding: 16px;
        border-radius: 16px;
      }

      #ezba-custom .ezba-cards { grid-template-columns: 1fr; }
      #ezba-custom .ezba-actions { flex-direction: column; }
      #ezba-custom .ezba-btn { width: 100%; }
    }
  </style>

  <div id="ezba-custom">
    <div class="ezba-wrap">
      <div class="ezba-head">
        <p class="ezba-kicker">Frequency tool</p>
        <h2 class="ezba-title">EZ DB's Bass Frequency Analyzer</h2>
        <p class="ezba-intro">Upload a song or rebassed track to see where the strongest bass content lives. This helps point you toward the enclosure style that may best fit your goals.</p>
      </div>

      <div class="ezba-grid">
        <div class="ezba-panel ezba-panel-main">
          <div class="ezba-controls">
            <label class="ezba-label" for="ezba-file">Upload audio file</label>
            <input id="ezba-file" class="ezba-file" type="file" accept="audio/mpeg,audio/mp3,audio/wav,audio/x-wav,audio/mp4,audio/x-m4a,audio/aac,audio/*">
            <p class="ezba-help">Supported: MP3, WAV, M4A, AAC. Files up to 25 MB. Analysis uses a high-resolution FFT for 10–80 Hz.</p>

            <div class="ezba-actions">
              <button type="button" class="ezba-btn ezba-btn-primary" id="ezba-analyze">Analyze track</button>
              <button type="button" class="ezba-btn ezba-btn-secondary" id="ezba-reset">Reset</button>
            </div>
          </div>

          <div class="ezba-status" id="ezba-status" aria-live="polite">Waiting for file.</div>

          <div class="ezba-results" id="ezba-results" style="display:none;">
            <div class="ezba-cards">
              <article class="ezba-card">
                <span class="ezba-card-label">Strongest bass peak</span>
                <strong class="ezba-card-value" id="ezba-main-peak">-- Hz</strong>
              </article>
              <article class="ezba-card">
                <span class="ezba-card-label">Main bass range</span>
                <strong class="ezba-card-value" id="ezba-main-range">--</strong>
              </article>
              <article class="ezba-card">
                <span class="ezba-card-label">Suggested direction</span>
                <strong class="ezba-card-value" id="ezba-suggestion">--</strong>
              </article>
            </div>

            <div class="ezba-peak-list-wrap">
              <span class="ezba-label">Highlighted peaks (10–80 Hz)</span>
              <div class="ezba-peak-list" id="ezba-peak-list"></div>
            </div>

            <div class="ezba-chart-wrap">
              <canvas id="ezba-chart" height="340"></canvas>
            </div>

            <div class="ezba-copy">
              <p class="ezba-recommendation" id="ezba-recommendation"></p>
              <p class="ezba-disclaimer">This tool analyzes the song’s frequency content, not your vehicle’s in-car response. Final enclosure choices should still consider available space, subwoofer specs, and your goals.</p>
            </div>
          </div>
        </div>

        <aside class="ezba-panel ezba-panel-side">
          <h3 class="ezba-side-title">How to use it</h3>
          <ol class="ezba-steps">
            <li>Upload a track you listen to often.</li>
            <li>Look at where the strongest bass peaks land between 10 Hz and 80 Hz.</li>
            <li>Use that result to help decide which enclosure type you should choose.</li>
          </ol>

          <div class="ezba-guide-box">
            <h4 class="ezba-guide-title">Quick enclosure guide</h4>
            <ul class="ezba-guide-list">
              <li><strong>Sealed:</strong> simplest and compact, not the main pick for heavy low-end chasing.</li>
              <li><strong>Ported:</strong> safest all-around recommendation for most daily builds.</li>
              <li><strong>4th order:</strong> best treated as a narrower-purpose candidate.</li>
              <li><strong>6th order:</strong> strongest candidate when deep lows and wider bandwidth both matter, if space allows.</li>
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </div>

  <script>
    (function() {
      var root = document.getElementById('ezba-custom');
      if (!root || root.getAttribute('data-ezba-bound') === 'true') return;
      root.setAttribute('data-ezba-bound', 'true');

      var API_BASE = 'https://ezdb-audio-analyzer-production.up.railway.app';

      var fileInput = document.getElementById('ezba-file');
      var analyzeBtn = document.getElementById('ezba-analyze');
      var resetBtn = document.getElementById('ezba-reset');
      var statusEl = document.getElementById('ezba-status');
      var resultsEl = document.getElementById('ezba-results');
      var peakEl = document.getElementById('ezba-main-peak');
      var rangeEl = document.getElementById('ezba-main-range');
      var suggestionEl = document.getElementById('ezba-suggestion');
      var recommendationEl = document.getElementById('ezba-recommendation');
      var peakListEl = document.getElementById('ezba-peak-list');
      var canvas = document.getElementById('ezba-chart');
      var ctx = canvas.getContext('2d');

      var CONFIG = {
        minHz: 10,
        maxHz: 80,
        maxFileMB: 25
      };

      var lastData = null;

      function setStatus(message) {
        statusEl.textContent = message;
      }

      function resetUI() {
        resultsEl.style.display = 'none';
        peakEl.textContent = '-- Hz';
        rangeEl.textContent = '--';
        suggestionEl.textContent = '--';
        recommendationEl.textContent = '';
        peakListEl.innerHTML = '';
        lastData = null;
        setStatus('Waiting for file.');
        clearCanvas();
      }

      // Plot area margins: room for axis titles and tick labels
      var PAD = { left: 52, right: 18, top: 22, bottom: 52 };
      var CHART_HEIGHT = 340;
      var CURRENT_DB_MIN = -60;
      var CURRENT_DB_MAX = 0;

      function clearCanvas() {
        var ratio = window.devicePixelRatio || 1;
        var width = canvas.clientWidth || 600;
        var height = CHART_HEIGHT;
        canvas.width = width * ratio;
        canvas.height = height * ratio;
        canvas.style.height = height + 'px';
        canvas.style.width = width + 'px';
        ctx.setTransform(ratio, 0, 0, ratio, 0, 0);
        ctx.clearRect(0, 0, width, height);
        ctx.fillStyle = '#1e1e21';
        ctx.fillRect(0, 0, width, height);
        drawAxes(width, height, CURRENT_DB_MIN, CURRENT_DB_MAX);
      }

      function plotWidth(width)  { return width  - PAD.left - PAD.right;  }
      function plotHeight(height){ return height - PAD.top  - PAD.bottom; }

      function xForFreq(freq, width) {
        var minLog = Math.log(CONFIG.minHz) / Math.LN10;
        var maxLog = Math.log(CONFIG.maxHz) / Math.LN10;
        var frac = (Math.log(freq) / Math.LN10 - minLog) / (maxLog - minLog);
        return PAD.left + frac * plotWidth(width);
      }

      function yForDb(db, height, minDb, maxDb) {
        var clamped = Math.max(minDb, Math.min(maxDb, db));
        var frac = (clamped - minDb) / (maxDb - minDb);
        return PAD.top + (1 - frac) * plotHeight(height);
      }

      function drawAxes(width, height, minDb, maxDb) {
        var pw = plotWidth(width);
        var ph = plotHeight(height);
        var plotLeft   = PAD.left;
        var plotRight  = PAD.left + pw;
        var plotTop    = PAD.top;
        var plotBottom = PAD.top + ph;

        // Plot background
        ctx.fillStyle = '#141416';
        ctx.fillRect(plotLeft, plotTop, pw, ph);

        // Vertical grid lines (frequency)
        ctx.strokeStyle = 'rgba(255,255,255,0.08)';
        ctx.lineWidth = 1;
        var xGrid = [10, 15, 20, 25, 30, 35, 40, 50, 60, 70, 80];
        xGrid.forEach(function(freq) {
          var x = xForFreq(freq, width);
          ctx.beginPath();
          ctx.moveTo(x, plotTop);
          ctx.lineTo(x, plotBottom);
          ctx.stroke();
        });

        // Horizontal grid lines (dB) — 10 dB steps
        var dbStep = 10;
        var firstDb = Math.ceil(minDb / dbStep) * dbStep;
        ctx.font = '11px Arial, sans-serif';
        ctx.fillStyle = 'rgba(255,255,255,0.56)';
        ctx.textAlign = 'right';
        ctx.textBaseline = 'middle';
        for (var d = firstDb; d <= maxDb; d += dbStep) {
          var y = yForDb(d, height, minDb, maxDb);
          ctx.strokeStyle = 'rgba(255,255,255,0.08)';
          ctx.beginPath();
          ctx.moveTo(plotLeft, y);
          ctx.lineTo(plotRight, y);
          ctx.stroke();
          ctx.fillText(d.toString(), plotLeft - 8, y);
        }

        // Axis lines
        ctx.strokeStyle = 'rgba(255,255,255,0.35)';
        ctx.lineWidth = 1;
        ctx.beginPath();
        ctx.moveTo(plotLeft, plotTop);
        ctx.lineTo(plotLeft, plotBottom);
        ctx.lineTo(plotRight, plotBottom);
        ctx.stroke();

        // X-axis tick labels
        ctx.fillStyle = 'rgba(255,255,255,0.72)';
        ctx.font = '11px Arial, sans-serif';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'top';
        var xTickLabels = [10, 20, 30, 40, 50, 60, 80];
        xTickLabels.forEach(function(freq) {
          var x = xForFreq(freq, width);
          // Small tick mark
          ctx.strokeStyle = 'rgba(255,255,255,0.35)';
          ctx.beginPath();
          ctx.moveTo(x, plotBottom);
          ctx.lineTo(x, plotBottom + 4);
          ctx.stroke();
          ctx.fillStyle = 'rgba(255,255,255,0.72)';
          ctx.fillText(freq.toString(), x, plotBottom + 7);
        });

        // X-axis title
        ctx.fillStyle = '#ffffff';
        ctx.font = 'bold 12px Arial, sans-serif';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'alphabetic';
        ctx.fillText('Frequency (Hz)', plotLeft + pw / 2, height - 10);

        // Y-axis title (rotated)
        ctx.save();
        ctx.translate(14, plotTop + ph / 2);
        ctx.rotate(-Math.PI / 2);
        ctx.fillStyle = '#ffffff';
        ctx.font = 'bold 12px Arial, sans-serif';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText('dB', 0, 0);
        ctx.restore();

        // Reset text alignment defaults for callers
        ctx.textAlign = 'left';
        ctx.textBaseline = 'alphabetic';
      }

      function drawSpectrum(points, peaks) {
        if (!points || !points.length) { clearCanvas(); return; }

        var width = canvas.clientWidth || 600;
        var height = CHART_HEIGHT;

        // Compute dB range from data
        var dataMin = 0;
        for (var i = 0; i < points.length; i++) {
          if (points[i].db < dataMin) dataMin = points[i].db;
        }
        var minDb = Math.max(-90, Math.floor((dataMin - 3) / 10) * 10);
        if (minDb > -30) minDb = -30;
        var maxDb = 0;
        CURRENT_DB_MIN = minDb;
        CURRENT_DB_MAX = maxDb;

        clearCanvas();

        var pw = plotWidth(width);
        var ph = plotHeight(height);
        var plotLeft   = PAD.left;
        var plotBottom = PAD.top + ph;

        // Clip to plot area
        ctx.save();
        ctx.beginPath();
        ctx.rect(plotLeft, PAD.top, pw, ph);
        ctx.clip();

        // Gradient fill
        var gradient = ctx.createLinearGradient(0, PAD.top, 0, plotBottom);
        gradient.addColorStop(0, 'rgba(232,164,0,0.55)');
        gradient.addColorStop(1, 'rgba(232,164,0,0.05)');

        ctx.beginPath();
        ctx.moveTo(xForFreq(points[0].hz, width), yForDb(points[0].db, height, minDb, maxDb));
        for (var j = 1; j < points.length; j++) {
          ctx.lineTo(xForFreq(points[j].hz, width), yForDb(points[j].db, height, minDb, maxDb));
        }
        ctx.lineTo(xForFreq(points[points.length - 1].hz, width), plotBottom);
        ctx.lineTo(xForFreq(points[0].hz, width), plotBottom);
        ctx.closePath();
        ctx.fillStyle = gradient;
        ctx.fill();

        // Spectrum line
        ctx.beginPath();
        ctx.moveTo(xForFreq(points[0].hz, width), yForDb(points[0].db, height, minDb, maxDb));
        for (var k = 1; k < points.length; k++) {
          ctx.lineTo(xForFreq(points[k].hz, width), yForDb(points[k].db, height, minDb, maxDb));
        }
        ctx.strokeStyle = '#e8a400';
        ctx.lineWidth = 2;
        ctx.stroke();
        ctx.restore();

        // Peak markers with staggered non-overlapping labels
        if (peaks && peaks.length) {
          var placed = []; // array of {x, y, w, h}
          ctx.font = 'bold 12px Arial, sans-serif';
          ctx.textAlign = 'left';
          ctx.textBaseline = 'alphabetic';

          peaks.forEach(function(hz, idx) {
            var closest = points[0];
            for (var p = 1; p < points.length; p++) {
              if (Math.abs(points[p].hz - hz) < Math.abs(closest.hz - hz)) closest = points[p];
            }
            var px = xForFreq(closest.hz, width);
            var py = yForDb(closest.db, height, minDb, maxDb);

            // Marker
            ctx.beginPath();
            ctx.arc(px, py, idx === 0 ? 7 : 5, 0, Math.PI * 2);
            ctx.fillStyle = idx === 0 ? '#ffffff' : 'rgba(255,255,255,0.85)';
            ctx.fill();
            ctx.strokeStyle = '#e8a400';
            ctx.lineWidth = 2;
            ctx.stroke();

            // Label placement — try above, then below, avoid overlaps
            var label = Math.round(hz) + ' Hz';
            var lw = ctx.measureText(label).width;
            var lh = 14;
            var lx = Math.max(plotLeft + 2, Math.min(plotLeft + pw - lw - 2, px - lw / 2));
            var candidatesY = [py - 14, py + 20, py - 28, py + 34];
            var ly = candidatesY[0];
            for (var c = 0; c < candidatesY.length; c++) {
              var testY = candidatesY[c];
              if (testY < PAD.top + 4 || testY > plotBottom - 2) continue;
              var collides = false;
              for (var pp = 0; pp < placed.length; pp++) {
                var a = placed[pp];
                if (lx < a.x + a.w + 2 && lx + lw + 2 > a.x && testY - lh < a.y && testY > a.y - a.h) {
                  collides = true; break;
                }
              }
              if (!collides) { ly = testY; break; }
            }

            // Label background pill for readability
            ctx.fillStyle = 'rgba(0,0,0,0.55)';
            ctx.fillRect(lx - 4, ly - lh + 2, lw + 8, lh + 2);
            ctx.fillStyle = '#ffffff';
            ctx.fillText(label, lx, ly);

            placed.push({ x: lx, y: ly, w: lw + 8, h: lh });
          });
        }
      }

      function classify(strongestHz, peaks, bands) {
        if (!strongestHz) {
          return {
            label: 'Ported',
            text: 'No strong bass peak stood out clearly, so ported is the safest all-around starting point for most daily builds.'
          };
        }

        var top = strongestHz;

        if (top < 25 && bands.low >= bands.mid) {
          return {
            label: 'Low-tuned ported / 6th order candidate',
            text: 'This track leans deep with strong low-bass content. A low-tuned ported design is the safer recommendation, while a 6th order may be worth discussing if you have the space and want wider low-end bandwidth.'
          };
        }

        if (bands.mid >= bands.low && bands.mid >= bands.upper) {
          return {
            label: 'Ported',
            text: 'The strongest bass energy sits in the common daily range, which makes ported the best all-around recommendation for most builds.'
          };
        }

        if (bands.upper > bands.mid && bands.upper >= bands.low) {
          return {
            label: 'Higher-tuned ported',
            text: 'This track has more upper-bass emphasis than deep extension, which points more toward an output-focused ported setup.'
          };
        }

        return {
          label: '4th / 6th order candidate',
          text: 'The track shows a more specialized bass profile than a typical daily-only song. A bandpass option may be worth considering, but final direction should still depend on your subwoofer, space, and goals.'
        };
      }

      function renderResults(data) {
        var strongest = data.strongest_peak_hz;
        var peaks = Array.isArray(data.peak_list_10_80) ? data.peak_list_10_80 : [];
        var points = Array.isArray(data.graph_points_10_80) ? data.graph_points_10_80 : [];
        var bands = data.bands || { low: -120, mid: -120, upper: -120 };

        peakEl.textContent = strongest ? Math.round(strongest) + ' Hz' : 'No clear peak';

        if (peaks.length) {
          var sorted = peaks.slice().sort(function(a, b) { return a - b; });
          rangeEl.textContent = Math.round(sorted[0]) + '–' + Math.round(sorted[sorted.length - 1]) + ' Hz';
        } else {
          rangeEl.textContent = 'No clear peak';
        }

        var suggestion = classify(strongest, peaks, bands);
        suggestionEl.textContent = suggestion.label;
        recommendationEl.textContent = suggestion.text;

        peakListEl.innerHTML = '';
        if (peaks.length) {
          peaks.forEach(function(hz) {
            var chip = document.createElement('span');
            chip.className = 'ezba-chip';
            chip.textContent = Math.round(hz) + ' Hz';
            peakListEl.appendChild(chip);
          });
        } else {
          var chip = document.createElement('span');
          chip.className = 'ezba-chip';
          chip.textContent = 'No clear peak detected';
          peakListEl.appendChild(chip);
        }

        drawSpectrum(points, peaks);
        resultsEl.style.display = 'grid';
      }

      async function runAnalysis() {
        var file = fileInput.files && fileInput.files[0];
        if (!file) {
          setStatus('Choose an audio file first.');
          return;
        }

        var sizeMB = file.size / (1024 * 1024);
        if (sizeMB > CONFIG.maxFileMB) {
          setStatus('File is ' + sizeMB.toFixed(1) + ' MB. Please use a file under ' + CONFIG.maxFileMB + ' MB.');
          return;
        }

        analyzeBtn.disabled = true;
        resetBtn.disabled = true;
        setStatus('Uploading and analyzing (this can take 10–30 seconds)...');
        resultsEl.style.display = 'none';

        try {
          var form = new FormData();
          form.append('file', file);

          var res = await fetch(API_BASE + '/analyze', {
            method: 'POST',
            body: form
          });

          if (!res.ok) {
            var errMsg = 'Analysis failed (' + res.status + ').';
            try {
              var errData = await res.json();
              if (errData && errData.detail) errMsg = errData.detail;
            } catch (e) {}
            throw new Error(errMsg);
          }

          var data = await res.json();
          lastData = data;
          renderResults(data);
          setStatus('Analysis complete. Strongest peak at ' + Math.round(data.strongest_peak_hz) + ' Hz.');
        } catch (err) {
          console.error(err);
          setStatus(err.message || 'Analysis failed. Please try again with a different file.');
          resultsEl.style.display = 'none';
          clearCanvas();
        } finally {
          analyzeBtn.disabled = false;
          resetBtn.disabled = false;
        }
      }

      analyzeBtn.addEventListener('click', runAnalysis);
      resetBtn.addEventListener('click', function() {
        fileInput.value = '';
        resetUI();
      });

      fileInput.addEventListener('change', function() {
        if (fileInput.files && fileInput.files[0]) {
          setStatus('Ready: ' + fileInput.files[0].name);
        }
      });

      window.addEventListener('resize', function() {
        if (lastData) {
          drawSpectrum(lastData.graph_points_10_80, lastData.peak_list_10_80);
        } else {
          clearCanvas();
        }
      });

      clearCanvas();
    })();
  </script>
  {% endcapture %}

  <div class="rte{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
    {{ page.content | replace: '[[BASS_ANALYZER]]', bass_analyzer_markup }}
  </div>

  {% unless page.handle == 'merch' or page.handle == 'cut-sheet-generator' or page.handle == 'gallery' or page.handle == 'contact' %}
  <div class="page-cta-block{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
    <h2 class="cta-heading">Ready to Get Your Custom Blueprint?</h2>
    <p class="cta-text">Place your order today and receive a precision-engineered subwoofer enclosure design built specifically for your vehicle and subs.</p>
    <div class="cta-buttons">
      <a href="/collections/custom-box-designs" class="button--cta-primary">Browse Custom Designs</a>
      <a href="/pages/how-to-order-a-custom-box-design" class="button--cta-secondary">How To Order</a>
    </div>
  </div>
  {% endunless %}
</div>

